# Web app (Next.js) environment.
# NEXT_PUBLIC_* are inlined into the client bundle at BUILD time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:1337
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side (SSR/route handlers) API base — may be an internal URL in prod.
API_BASE_URL=http://localhost:1337

# Docker/Coolify host-Nginx upstream port. The Compose deployment binds this
# to 127.0.0.1 only; public traffic still enters through the reverse proxy.
PORT_INTERNAL=28721

# Local docker builds only: permits localhost NEXT_PUBLIC_* values in the
# image. NEVER set this in Coolify — the build guard exists so a deploy with
# missing build args fails instead of shipping a localhost bundle.
ALLOW_LOCALHOST_PUBLIC_URLS=true
